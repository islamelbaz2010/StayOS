# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/stayos

# Redis
REDIS_URL=redis://localhost:6379/0

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Firebase
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# Paymob
PAYMOB_API_KEY=
PAYMOB_HMAC_SECRET=

# WhatsApp / Meta
META_WHATSAPP_TOKEN=
META_PHONE_NUMBER_ID=

# AWS S3
S3_LISTINGS_BUCKET=
S3_KYC_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Sentry
SENTRY_DSN=

# OTP Configuration
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=3
OTP_RATE_LIMIT_WINDOW=900

# Calendar Lock
CALENDAR_LOCK_TIMEOUT_MS=5000
