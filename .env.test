# Database - Test
DATABASE_URL=postgresql+asyncpg://test:test@localhost:5432/stayos_test

# Redis - Test
REDIS_URL=redis://localhost:6379/1

# Environment
ENVIRONMENT=test
LOG_LEVEL=DEBUG

# CORS
CORS_ORIGINS=http://localhost:3000

# Firebase - Test (fake credentials)
FIREBASE_PROJECT_ID=test-project
FIREBASE_CLIENT_EMAIL=test@test-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\ntest\n-----END PRIVATE KEY-----\n"

# Twilio - Test (fake credentials)
TWILIO_ACCOUNT_SID=test_sid
TWILIO_AUTH_TOKEN=test_token
TWILIO_VERIFY_SERVICE_SID=test_service_sid

# Paymob - Test (fake credentials)
PAYMOB_API_KEY=test_api_key
PAYMOB_HMAC_SECRET=test_hmac_secret

# WhatsApp / Meta - Test (fake credentials)
META_WHATSAPP_TOKEN=test_token
META_PHONE_NUMBER_ID=test_phone_id

# AWS S3 - Test (fake credentials)
S3_LISTINGS_BUCKET=test-listings
S3_KYC_BUCKET=test-kyc
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test_access_key
AWS_SECRET_ACCESS_KEY=test_secret_key

# Sentry - Test (disabled for tests)
SENTRY_DSN=

# OTP Configuration
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=3
OTP_RATE_LIMIT_WINDOW=900

# Calendar Lock
CALENDAR_LOCK_TIMEOUT_MS=5000
