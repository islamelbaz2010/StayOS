/build/
/dist/
/bin/
/lib/
*.o
*.a
*.so
*.dylib
*.dll
*.exe

# Rust
Cargo.lock
**/*.rs.bk
.cargo/

# C++
*.o
*.obj
*.so
*.dylib
*.dll
*.exe
*.out
*.app
*.i86
*.x86_64
*.hex

# OS-specific
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-workspace
*.sublime-project

# Logs
*.log
logs/
*.log.*

# Testing
.coverage
coverage/
*.cover
.hypothesis/
.pytest_cache/
.nyc_output/

# Documentation
/docs/_build/
/docs/.doctrees/
/site/

# Temporary files
tmp/
temp/
*.tmp
*.temp
*.bak
*.backup

# Environment
.env
.env.local
.env.*.local
*.env

# Secrets
*.key
*.pem
*.crt
secrets/
*.secret

# Database
*.db
*.sqlite
*.sqlite3

# Package files
*.tar.gz
*.zip
*.rar
*.7z

# Node modules (if using any node tools)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Python (if using any python tools)
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Kernel specific
kernel.img
kernel.bin
*.iso
*.img

# Bootloader
bootloader/
boot/

# User space
userspace/
apps/

# Drivers
drivers/*.ko
drivers/*.o

# Documentation builds
docs/build/
docs/output/

# CI/CD
.github/workflows/*.log

# Backup files
*.orig
*.rej

